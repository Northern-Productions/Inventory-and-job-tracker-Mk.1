# Runtime mode: proxy (current), supabase (future)
BACKEND_MODE=proxy

# Required for proxy mode
APPS_SCRIPT_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Backend HTTP settings
PORT=3000
CORS_ALLOWED_ORIGINS=*

# Cache read responses from Apps Script to reduce repeated latency (milliseconds)
CACHE_TTL_MS=30000
MAX_CACHE_ENTRIES=500

# Future Supabase mode (not required in proxy mode)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
