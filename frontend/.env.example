# Local dev with Vite proxy
VITE_API_BASE_URL=/api

# Optional: use hosted backend in production/staging
# VITE_API_BASE_URL=https://your-backend.onrender.com/api
# Optional: use Supabase Edge Function backend host
# VITE_API_BASE_URL=https://YOUR_PROJECT_REF.supabase.co/functions/v1/api-proxy

VITE_PROXY_TARGET=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec
VITE_GOOGLE_CLIENT_ID=YOUR_GOOGLE_WEB_CLIENT_ID.apps.googleusercontent.com
